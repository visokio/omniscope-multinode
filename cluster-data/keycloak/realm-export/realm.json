{
  "realm": "visokio",
  "enabled": true,
  "displayName": "Visokio Omniscope",
  "displayNameHtml": "<b>Visokio Omniscope</b>",

  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "duplicateEmailsAllowed": false,
  "resetPasswordAllowed": true,
  "editUsernameAllowed": false,
  "bruteForceProtected": true,

  "accessTokenLifespan": 300,
  "ssoSessionIdleTimeout": 1800,
  "ssoSessionMaxLifespan": 36000,

  "roles": {
    "realm": [
      {
        "name": "editor-role",
        "description": "Omniscope editor — full read/write access, workflow execution"
      },
      {
        "name": "viewer-role",
        "description": "Omniscope viewer — read-only access to reports and dashboards"
      }
    ]
  },

  "clients": [
    {
      "clientId": "omniscope-editor",
      "name": "Omniscope Editor",
      "description": "OIDC client for the Omniscope editor cluster",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "omniscope-editor-secret-change-in-production",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://editor.localhost:9090/oidc-cb",
        "http://editor.localhost:9090/oidc-locb",
        "http://localhost:9090/oidc-cb",
        "http://localhost:9090/oidc-locb",
        "http://localhost:8080/oidc-cb",
        "http://localhost:8080/oidc-locb"
      ],
      "webOrigins": [
        "http://editor.localhost:9090",
        "http://localhost:9090",
        "http://localhost:8080"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://editor.localhost:9090/*##http://localhost:9090/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    },
    {
      "clientId": "omniscope-viewer",
      "name": "Omniscope Viewer",
      "description": "OIDC client for the Omniscope viewer cluster (behind nginx)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "omniscope-viewer-secret-change-in-production",
      "standardFlowEnabled": true,
      "implicitFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": [
        "http://viewer.localhost:9091/oidc-cb",
        "http://viewer.localhost:9091/oidc-locb",
        "http://localhost:9091/oidc-cb",
        "http://localhost:9091/oidc-locb",
        "http://viewer-node-1.localhost:19091/oidc-cb",
        "http://viewer-node-1.localhost:19091/oidc-locb",
        "http://viewer-node-2.localhost:19092/oidc-cb",
        "http://viewer-node-2.localhost:19092/oidc-locb",
        "http://localhost:19091/oidc-cb",
        "http://localhost:19091/oidc-locb",
        "http://localhost:19092/oidc-cb",
        "http://localhost:19092/oidc-locb"
      ],
      "webOrigins": [
        "http://viewer.localhost:9091",
        "http://localhost:9091",
        "http://viewer-node-1.localhost:19091",
        "http://viewer-node-2.localhost:19092",
        "http://localhost:19091",
        "http://localhost:19092"
      ],
      "attributes": {
        "post.logout.redirect.uris": "http://viewer.localhost:9091/*##http://localhost:9091/*##http://viewer-node-1.localhost:19091/*##http://viewer-node-2.localhost:19092/*##http://localhost:19091/*##http://localhost:19092/*"
      },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles"
      ]
    }
  ],

  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "roles"
  ],

  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      }
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "username",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "preferred_username",
            "jsonType.label": "String"
          }
        },
        {
          "name": "given name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "firstName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "given_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "family name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "lastName",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "family_name",
            "jsonType.label": "String"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "consentRequired": false,
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "true"
      },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "email",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email",
            "jsonType.label": "String"
          }
        },
        {
          "name": "email verified",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "consentRequired": false,
          "config": {
            "userinfo.token.claim": "true",
            "user.attribute": "emailVerified",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "email_verified",
            "jsonType.label": "boolean"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": {
        "include.in.token.scope": "false"
      },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "consentRequired": false,
          "config": {
            "multivalued": "true",
            "userinfo.token.claim": "true",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "claim.name": "roles",
            "jsonType.label": "String"
          }
        }
      ]
    }
  ],

  "users": [
    {
      "username": "editor-user-a",
      "email": "editor-a@visokio.local",
      "firstName": "Editor",
      "lastName": "User A",
      "enabled": true,
      "emailVerified": true,
      "createdTimestamp": 1700000000000,
      "credentials": [
        {
          "type": "password",
          "value": "editor123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "editor-role"
      ]
    },
    {
      "username": "editor-user-b",
      "email": "editor-b@visokio.local",
      "firstName": "Editor",
      "lastName": "User B",
      "enabled": true,
      "emailVerified": true,
      "createdTimestamp": 1700000000001,
      "credentials": [
        {
          "type": "password",
          "value": "editor123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "editor-role"
      ]
    },
    {
      "username": "viewer-user-a",
      "email": "viewer-a@visokio.local",
      "firstName": "Viewer",
      "lastName": "User A",
      "enabled": true,
      "emailVerified": true,
      "createdTimestamp": 1700000000002,
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer-role"
      ]
    },
    {
      "username": "viewer-user-b",
      "email": "viewer-b@visokio.local",
      "firstName": "Viewer",
      "lastName": "User B",
      "enabled": true,
      "emailVerified": true,
      "createdTimestamp": 1700000000003,
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer-role"
      ]
    },
    {
      "username": "viewer-user-c",
      "email": "viewer-c@visokio.local",
      "firstName": "Viewer",
      "lastName": "User C",
      "enabled": true,
      "emailVerified": true,
      "createdTimestamp": 1700000000004,
      "credentials": [
        {
          "type": "password",
          "value": "viewer123",
          "temporary": false
        }
      ],
      "realmRoles": [
        "viewer-role"
      ]
    }
  ]
}
